  "_metadata": {
    "description": "All-India SW Monsoon (Jun-Sep) rainfall departure and El Nino classification, 1951-2025",
    "sources": {
      "rainfall": "IMD All-India Monsoon Rainfall (JJAS) — imd.gov.in long-period average series. LPA = 868.6 mm (1971-2020 base)",
      "enso": "NOAA ONI — 3-month running mean of Nino-3.4 SST anomaly. El Nino year = JJA or JAS ONI >= +0.5°C",
      "cross_ref": "Parthasarathy et al. updated series; IMD annual monsoon reports; NOAA ERSSTv5 ONI"
    },
    "buckets": {
      "HIGH": "departure > +10% (Excess)",
      "NORMAL": "-10% to +10%",
      "LOW": "departure < -10% (Deficient)",
      "ELNINO_LOW": "El Nino year AND departure < -10%",
      "ELNINO_NORMAL": "El Nino year AND -10% to +10%",
      "ELNINO_HIGH": "El Nino year AND departure > +10%"
    },
    "notes": "Years tagged El Nino if JJA or JAS ONI >= 0.5. Some borderline years (0.4-0.5) excluded from El Nino tag."
  },
