    "elnino_years_total": 20,
    "elnino_breakdown": {
      "ELNINO_LOW": 8,
      "ELNINO_NORMAL": 11,
      "ELNINO_HIGH": 1
    },
    "key_insight": "Of 20 El Nino years (1951-2025), 8 had deficient monsoons (40%), 11 had normal monsoons (55%), and 1 had excess (5%). El Nino raises drought probability from base rate ~16% to ~40%, but majority of El Nino years still saw normal rainfall."
  },
  "2026_probability_model": {
    "description": "Probability weights for 2026 rainfall buckets, derived from: (1) IMD official forecast of 90% LPA ±5%, (2) current El Nino blended probability 68.2%, (3) current season-to-date departure -28%, (4) historical El Nino→rainfall conditional rates",
    "weights": {
      "LOW": 0.55,
      "NORMAL": 0.40,
      "HIGH": 0.05
    },
    "reasoning": "IMD forecast of 90% LPA centers the distribution below normal. With 68% El Nino probability and historical 40% drought rate in El Nino years, weighted P(LOW) = 0.68*0.40 + 0.32*0.16 ≈ 0.32 from climatology alone. But IMD's already-below-normal forecast and current -28% departure push this higher. Combined estimate: 55% LOW, 40% NORMAL, 5% HIGH.",
    "caveats": [
      "Early season (first 2 weeks of June) — departure can shift dramatically",
      "Negative PDO (-2.71) may mitigate El Nino impact",
      "IOD currently neutral — if it turns positive, odds improve significantly"
    ]
  }
